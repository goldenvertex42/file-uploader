<%- include('partials/header') %>
<body>
  <% if (locals.currentUser) { %>
    <div class="dash-container">
      <%- include('partials/navbar') %>
      <!-- Main Content -->
      <main class="dash-main">
        <header class="dash-header">
          <h1>Welcome, <%= currentUser.name %></h1>
          <div class="dash-actions">
            <button id="btn-new-folder" class="dash-btn dash-btn-outline">New Folder</button>
            <a href="/files/upload" class="dash-btn">Upload File</a>
          </div>
        </header>

        <h3 class="dash-section-title">My Folders</h3>
        <ul class="dash-list">
          <li id="new-folder-item" class="dash-item hidden">
            <form action="/folders/new" method="POST">
              <span class="icon">📁</span>
              <input 
                type="text" 
                name="name" 
                id="new-folder-input" 
                class="dash-input-inline" 
                value="New Folder"
                autocomplete="off"
              >
            </form>
          </li>
          <% if (folders.length > 0) { %>
            <% folders.forEach(folder => { %>
              <li class="dash-item">
                <a href="/folders/<%= folder.id %>" class="dash-item-link">
                  <span class="icon">📁</span> <%= folder.name %>
                </a>
              </li>
            <% }) %>
          <% } else { %>
            <p>There are no folders to display.</p>
          <% } %>
        </ul>

        <h3 class="dash-section-title">My Files</h3>
        <ul class="dash-list">
          <% if (files.length > 0) { %>
            <% files.forEach(file => { %>
              <li class="dash-item">
                <a href="/files/<%= file.id %>" class="dash-item-link">
                  <span class="icon">📄</span> 
                  <span class="file-name-text"><%= file.name %></span>
                  <span class="file-meta"><%= formatSize(file.size) %></span>
                </a>
              </li>
            <% }) %>
          <% } else { %>
            <p>There are no files in the root directory.</p>
          <% } %>
        </ul>
      </main>
    </div>
  <% } else { %>
    <!-- Reusing Auth Page styles for the Hero/Logged-out state -->
    <div class="auth-page">
      <div class="auth-card text-center">
        <h1 class="auth-title">Deep Thought Vault</h1>
        <p class="light-gray mb-1">Secure cloud storage for your project files.</p>
        <a href="/sign-up" class="auth-btn btn-block">Get Started</a>
        <p class="auth-footer light-gray">Already a member? <a href="/login">Log in</a></p>
      </div>
    </div>
  <% } %>
  <script src="/js/dashboard.js"></script>
<%- include('partials/footer') %>

