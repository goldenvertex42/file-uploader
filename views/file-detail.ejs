<%- include('partials/header') %>
<div class="dash-container">
  <%- include('partials/navbar') %>
  
  <main class="dash-main">
    <div class="auth-card file-card">
      <header class="file-card-header">
        <div id="file-title-container" class="folder-header-title">
          <h1 class="file-card-name">📄 <%= file.name %></h1>
          <button id="btn-edit-file" class="btn-rename-small">Rename File</button>
        </div>

        <!-- Hidden Rename Form -->
        <form id="rename-file-form" action="/files/<%= file.id %>/update" method="POST" class="hidden">
          <input 
            type="text" 
            name="name" 
            id="rename-file-input" 
            class="dash-input-title" 
            value="<%= file.name %>"
            autocomplete="off"
          >
        </form>
      </header>
      
      <div class="file-info-grid">
        <span class="info-label">Size</span>
        <span class="info-value"><%= formatSize(file.size) %></span>

        <span class="info-label">Type</span>
        <span class="info-value"><%= file.name.split('.').pop().toUpperCase() %> File</span>

        <span class="info-label">Uploaded</span>
        <span class="info-value"><%= file.createdAt.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' }) %></span>
      </div>

      <div class="dash-actions">
        <% const downloadUrl = file.url.replace('/upload/', '/upload/fl_attachment/') %>
        <a href="<%= downloadUrl %>" class="dash-btn">Download File</a>
        
        <!-- Delete File Form -->
        <form action="/files/<%= file.id %>/delete" method="POST" onsubmit="return confirm('Permanently delete this file?')">
          <button type="submit" class="dash-btn dash-btn-outline delete-btn">Delete</button>
        </form>
        
        <a href="/folders/<%= file.folderId %>" class="dash-btn dash-btn-outline right-side">Back</a>
      </div>
    </div>
  </main>
</div>
<script src="/js/dashboard.js"></script>
<%- include('partials/footer') %>
