<%- include('partials/header') %>
<body class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title"><%= title %></h1>

    <form action="/sign-up" method="POST">
      <label class="auth-label" for="name">Full Name</label>
      <input class="auth-input" type="text" id="name" name="name" value="<%= locals.formData ? formData.name : '' %>" required>

      <label class="auth-label" for="email">Email</label>
      <input class="auth-input" type="email" id="email" name="email" value="<%= locals.formData ? formData.email : '' %>" required>

      <label class="auth-label" for="password">Password</label>
      <input class="auth-input" type="password" id="password" name="password" required>

      <label class="auth-label" for="confirmPassword">Confirm Password</label>
      <input class="auth-input" type="password" id="confirmPassword" name="confirmPassword" required>

      <button class="auth-btn" type="submit">Sign Up</button>
    </form>

    <% if (locals.errors) { %>
      <ul class="error-list">
        <% errors.forEach(error => { %>
          <li class="error-item"><%= error.msg %></li>
        <% }) %>
      </ul>
    <% } %>

    <p class="auth-footer">Already have an account? <a href="/login">Log in here</a></p>
  </div>
<%- include('partials/footer') %>
